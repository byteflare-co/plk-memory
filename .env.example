PLK_DATA_REPO_URL=git@github.com:cutsome/agent-organization.git
PLK_TOKENS={"dev-token-claude-code":"claude-code","dev-token-codex":"codex","dev-token-hermes":"hermes","dev-token-agent":"custom-agent"}
PLK_ADMIN_TOKEN=dev-admin-token

# PostgreSQL-primary 開発時。既存ランタイムは storage_backend=git が既定。
# PLK_STORAGE_BACKEND=postgres
# PLK_DATABASE_URL=postgresql://plk:plk@127.0.0.1:5432/plk
# PLK_DEFAULT_ORGANIZATION_ID=00000000-0000-0000-0000-000000000001
# PLK_REQUIRE_IDEMPOTENCY_KEY=true
# PLK_REQUIRE_EXPECTED_REVISION=true
# ANTHROPIC_API_KEY は環境変数から継承する（.env に書かない。llm_provider=anthropic の場合のみ必要）

# ingest LLM（graphiti のグラフ構築用）。既定はローカル Ollama（Anthropic API を消費しない）。
# 事前に `ollama pull gpt-oss:20b` でモデルを取得しておくこと。
# PLK_LLM_PROVIDER=openai-compatible
# PLK_LLM_BASE_URL=http://localhost:11434/v1
# PLK_LLM_MODEL=gpt-oss:20b
# PLK_LLM_API_KEY=ollama
# Anthropic API を使う場合（組織展開 逆輸入用など）: PLK_LLM_PROVIDER=anthropic（ANTHROPIC_API_KEY を export）

# 認証モード（既定 bearer）。Phase 3 の JWT 換装実測時のみ jwt にする。
# PLK_AUTH_MODE=jwt
# PLK_JWKS_URI=http://127.0.0.1:8735/.well-known/jwks.json   # ローカル JWKS 配信
# PLK_JWT_ISSUER=https://plk-memory.local/
# PLK_JWT_AUDIENCE=plk-memory
# JWT/JWKS の発行: uv run python -m scripts.auth.issue_jwt
